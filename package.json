{
  "name": "krriyos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "dev:full": "concurrently \"node server.js\" \"vite\"",
    "build": "vue-tsc -b && vite build && pnpm prisma migrate deploy",
    "start": "node server.js",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage"
  },
  "dependencies": {
