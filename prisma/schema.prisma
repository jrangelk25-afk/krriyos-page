generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @unique
  description  String?
  slug         String    @unique
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  products     Product[]

  @@index([isActive])
  @@map("categories")
}

model Product {
  id                   String         @id @default(uuid()) @db.Uuid
  sku                  String         @unique
  name                 String
  description          String?
  price                Decimal        @db.Decimal(10, 2)
  discountPercentage   Int            @default(0) @map("discount_percentage")
  categoryId           String         @map("category_id") @db.Uuid
  stock                Int            @default(0)
  isNewArrival         Boolean        @default(false) @map("is_new_arrival")
  isOutlet             Boolean        @default(false) @map("is_outlet")
  isActive             Boolean        @default(true) @map("is_active")
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy            String?        @map("created_by") @db.Uuid
  updatedBy            String?        @map("updated_by") @db.Uuid
  orderItems           OrderItem[]
  colors               ProductColor[]
  images               ProductImage[]
  sizes                ProductSize[]
  category             Category       @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([sku])
  @@index([isActive])
  @@index([isOutlet])
  @@map("products")
}

model ProductColor {
  id           String              @id @default(uuid()) @db.Uuid
  productId    String              @map("product_id") @db.Uuid
  name         String?
  hexCode      String?             @map("hex_code")
  displayOrder Int                 @default(0) @map("display_order")
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  product      Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  images       ProductImage[]
  sizes        ProductSizeColor[]

  @@index([productId])
  @@map("product_colors")
}

model ProductSize {
  id        String              @id @default(uuid()) @db.Uuid
  productId String              @map("product_id") @db.Uuid
  size      String
  stock     Int                 @default(0)
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  colors    ProductSizeColor[]

  @@unique([productId, size])
  @@index([productId])
  @@map("product_sizes")
}

model ProductImage {
  id           String        @id @default(uuid()) @db.Uuid
  productId    String        @map("product_id") @db.Uuid
  colorId      String?       @map("color_id") @db.Uuid
  imageUrl     String        @map("image_url") @db.VarChar(500)
  altText      String?       @map("alt_text")
  displayOrder Int           @default(0) @map("display_order")
  isPrimary    Boolean       @default(false) @map("is_primary")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy    String?       @map("created_by") @db.Uuid
  color        ProductColor? @relation(fields: [colorId], references: [id])
  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([colorId])
  @@map("product_images")
}

model ProductSizeColor {
  id        String       @id @default(uuid()) @db.Uuid
  sizeId    String       @map("size_id") @db.Uuid
  colorId   String       @map("color_id") @db.Uuid
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  size      ProductSize  @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  color     ProductColor @relation(fields: [colorId], references: [id], onDelete: Cascade)

  @@unique([sizeId, colorId])
  @@index([sizeId])
  @@index([colorId])
  @@map("product_size_colors")
}

model Customer {
  id                     String   @id @default(uuid()) @db.Uuid
  email                  String   @unique
  fullName               String   @map("full_name")
  phone                  String
  isNewsletterSubscriber Boolean  @default(false) @map("is_newsletter_subscriber")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  orders                 Order[]

  @@index([email])
  @@map("customers")
}

model Order {
  id            String      @id @default(uuid()) @db.Uuid
  orderNumber   String      @unique @map("order_number")
  customerId    String      @map("customer_id") @db.Uuid
  fullName      String      @map("full_name")
  phone         String
  country       String
  city          String
  address       String
  zipCode       String?     @map("zip_code")
  subtotal      Decimal     @db.Decimal(10, 2)
  tax           Decimal     @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING)
  paymentMethod String?     @map("payment_method")
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  items         OrderItem[]
  customer      Customer    @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  size      String
  color     String?
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(10, 2)
  subtotal  Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model AdminUser {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  fullName     String     @map("full_name")
  role         AdminRole  @default(STAFF)
  isActive     Boolean    @default(true) @map("is_active")
  lastLogin    DateTime?  @map("last_login") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  auditLogs    AuditLog[]

  @@index([email])
  @@map("admin_users")
}

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  adminUserId String    @map("admin_user_id") @db.Uuid
  action      String
  tableName   String    @map("table_name")
  recordId    String?   @map("record_id") @db.Uuid
  changes     Json?
  ipAddress   String?   @map("ip_address")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_log")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum AdminRole {
  ADMIN
  STAFF
}
